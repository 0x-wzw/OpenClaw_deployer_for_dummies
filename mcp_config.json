{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/opt/openclaw"
      ]
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "openclaw_data.db"
      ]
    },
    "cloud-deployer": {
      "command": "python3",
      "args": [
        "mcp_servers/cloud_deployer.py"
      ],
      "description": "Cloud VM deployment server — supports AWS, GCP, Azure, DigitalOcean"
    }
  }
}
